<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TS_DJ.App.ViewModels"
        x:Class="TS_DJ.App.Views.SavePlaylistDialog"
        x:DataType="vm:SavePlaylistDialogViewModel"
        Title="Save Playlist"
        Width="400"
        Height="220"
        MinWidth="320"
        MinHeight="180"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto" Margin="16" RowSpacing="10">
        <TextBlock Grid.Row="0" Text="Save current queue as a playlist"/>
        <StackPanel Grid.Row="1" Spacing="4">
            <TextBlock Text="Name"/>
            <TextBox Text="{Binding Name}"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Spacing="4">
            <TextBlock Text="Description (optional)"/>
            <TextBox Text="{Binding Description}" AcceptsReturn="True" MinHeight="48"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" Click="CancelButton_OnClick"/>
            <Button Content="Save" Command="{Binding SaveCommand}" IsEnabled="{Binding CanSave}" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
