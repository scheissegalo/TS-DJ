<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TS_DJ.App.ViewModels"
        x:Class="TS_DJ.App.Views.YouTubeUrlDialog"
        x:DataType="vm:YouTubeUrlDialogViewModel"
        Title="YouTube URL"
        Width="520"
        Height="320"
        MinWidth="420"
        MinHeight="280"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="16" RowSpacing="10">
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="YouTube video URL"/>
            <TextBox Text="{Binding Url}" PlaceholderText="https://www.youtube.com/watch?v=…"/>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   Opacity="0.85"/>

        <Border Grid.Row="2" Padding="12" CornerRadius="8" BorderThickness="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                IsVisible="{Binding HasPreview}">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding PreviewTitle}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding PreviewUploader}" Opacity="0.85"/>
                <TextBlock Text="{Binding PreviewDuration}" Opacity="0.75"/>
            </StackPanel>
        </Border>

        <ProgressBar Grid.Row="3" IsIndeterminate="True" IsVisible="{Binding IsBusy}" Height="4"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" Click="CancelButton_OnClick"/>
            <Button Content="Add to Queue" Click="AddToQueueButton_OnClick" IsEnabled="{Binding CanConfirm}"/>
            <Button Content="Play Now" Click="PlayNowButton_OnClick" IsEnabled="{Binding CanConfirm}" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
